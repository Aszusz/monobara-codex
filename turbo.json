{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".vite/**"]
    },
    "typecheck": {
      "dependsOn": ["^typecheck"],
      "outputs": []
    },
    "//#bddgen:generate": {
      "inputs": [
        "playwright.config.ts",
        "tests/features/**/*.feature",
        "tests/steps/**/*.ts"
      ],
      "outputs": ["tests/.features-gen/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
