{
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "bun run dev:api & bun run dev:web",
    "dev:api": "bun --filter @monobara/api dev",
    "dev:web": "bun --filter @monobara/web dev",
    "build": "bun --filter '*' build",
    "preview": "bun --filter @monobara/web preview",
    "test": "bddgen test && playwright test",
    "format": "biome format --write .",
    "lint": "biome check --fix .",
    "typecheck": "tsc -b apps/api apps/web",
    "qual": "bun run format && bun run lint && bun run typecheck && bun run test"
  },
  "dependencies": {},
  "devDependencies": {
    "@biomejs/biome": "^2.5.2",
    "@playwright/test": "^1.61.1",
    "@types/node": "^26.1.0",
    "playwright-bdd": "^9.2.0",
    "typescript": "latest"
  }
}
