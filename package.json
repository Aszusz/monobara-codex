{
  "name": "monobara-codex",
  "private": true,
  "packageManager": "bun@1.3.11",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev --ui tui",
    "dev:api": "bun --filter @monobara/api dev",
    "dev:web": "bun --filter @monobara/web dev",
    "build": "turbo run build",
    "preview": "bun --filter @monobara/web preview",
    "bddgen": "turbo run //#bddgen:generate",
    "bddgen:generate": "bddgen test",
    "test": "bun run bddgen && playwright test",
    "format": "biome format --write .",
    "lint": "biome check --fix .",
    "typecheck": "turbo run typecheck",
    "qual": "bun run format && bun run lint && bun run typecheck && bun run test"
  },
  "dependencies": {},
  "devDependencies": {
    "@biomejs/biome": "^2.5.2",
    "@playwright/test": "^1.61.1",
    "@types/node": "^26.1.0",
    "playwright-bdd": "^9.2.0",
    "turbo": "latest",
    "typescript": "latest"
  }
}
