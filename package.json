{
  "name": "monobara-codex",
  "private": true,
  "packageManager": "bun@1.3.11",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "db:up": "docker compose up -d postgres",
    "db:generate": "bun --cwd packages/db drizzle-kit generate",
    "db:migrate": "bun --cwd packages/db drizzle-kit migrate",
    "db:push": "bun --cwd packages/db drizzle-kit push",
    "db:reset": "docker compose down -v && docker compose up -d postgres && bun run db:push",
    "db:studio": "bun --cwd packages/db drizzle-kit studio",
    "dev": "turbo run dev --ui tui",
    "build": "turbo run build",
    "preview": "bun --filter @monobara/web preview",
    "bddgen:cached": "bddgen test",
    "test": "turbo run bddgen:cached && playwright test",
    "format": "biome format --write .",
    "lint": "biome check --fix .",
    "typecheck": "turbo run typecheck",
    "qual": "bun run format && bun run lint && bun run typecheck && bun run test"
  },
  "dependencies": {},
  "devDependencies": {
    "@biomejs/biome": "^2.5.2",
    "@playwright/test": "^1.61.1",
    "@types/node": "^26.1.0",
    "playwright-bdd": "^9.2.0",
    "turbo": "latest",
    "typescript": "latest"
  }
}
